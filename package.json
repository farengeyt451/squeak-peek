{
  "name": "squeak-peek",
  "displayName": "Squeak Peek",
  "description": "Travel through any file's Git history - step backward and forward through commits and diff each revision against your working copy.",
  "version": "1.0.4",
  "publisher": "farengeyt451",
  "icon": "images/icon.png",
  "license": "MIT",
  "homepage": "https://github.com/farengeyt451/squeak-peek#readme",
  "bugs": {
    "url": "https://github.com/farengeyt451/squeak-peek/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/farengeyt451/squeak-peek.git"
  },
  "keywords": [
    "git",
    "history",
    "diff",
    "blame",
    "squeak peek",
    "revision",
    "log",
    "compare"
  ],
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "squeakPeek.prev",
        "title": "Squeak Peek: Previous Revision",
        "icon": "$(chevron-left)",
        "enablement": "squeakPeek:canPrev"
      },
      {
        "command": "squeakPeek.current",
        "title": "Squeak Peek: Show Position in History",
        "icon": {
          "light": "images/squeak-peek-light.svg",
          "dark": "images/squeak-peek-dark.svg"
        },
        "enablement": "squeakPeek:enabled"
      },
      {
        "command": "squeakPeek.next",
        "title": "Squeak Peek: Next Revision",
        "icon": "$(chevron-right)",
        "enablement": "squeakPeek:canNext"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "squeakPeek.prev",
          "group": "navigation@101",
          "when": "squeakPeek:enabled"
        },
        {
          "command": "squeakPeek.current",
          "group": "navigation@102",
          "when": "squeakPeek:enabled"
        },
        {
          "command": "squeakPeek.next",
          "group": "navigation@103",
          "when": "squeakPeek:enabled"
        }
      ]
    },
    "keybindings": [
      {
        "command": "squeakPeek.prev",
        "key": "ctrl+alt+,",
        "mac": "ctrl+cmd+,",
        "when": "editorTextFocus && squeakPeek:canPrev"
      },
      {
        "command": "squeakPeek.current",
        "key": "ctrl+alt+/",
        "mac": "ctrl+cmd+/",
        "when": "editorTextFocus && squeakPeek:enabled"
      },
      {
        "command": "squeakPeek.next",
        "key": "ctrl+alt+.",
        "mac": "ctrl+cmd+.",
        "when": "editorTextFocus && squeakPeek:canNext"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "package:vsix": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
