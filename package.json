{
  "name": "gtm-f541",
  "displayName": "git-time-machine",
  "description": "Step through a file's Git history with prev / current / next buttons.",
  "version": "1.0.1",
  "publisher": "farengeyt451",
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/farengeyt451/git-time-machine.git"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gtm.prev",
        "title": "Git Time Machine: Previous Revision",
        "icon": "$(chevron-left)",
        "enablement": "gtm:canPrev"
      },
      {
        "command": "gtm.current",
        "title": "Git Time Machine: Show Position in History",
        "icon": {
          "light": "images/gtm-cat-light.svg",
          "dark": "images/gtm-cat-dark.svg"
        },
        "enablement": "gtm:enabled"
      },
      {
        "command": "gtm.next",
        "title": "Git Time Machine: Next Revision",
        "icon": "$(chevron-right)",
        "enablement": "gtm:canNext"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "gtm.prev",
          "group": "navigation@101",
          "when": "gtm:enabled"
        },
        {
          "command": "gtm.current",
          "group": "navigation@102",
          "when": "gtm:enabled"
        },
        {
          "command": "gtm.next",
          "group": "navigation@103",
          "when": "gtm:enabled"
        }
      ]
    },
    "keybindings": [
      {
        "command": "gtm.prev",
        "key": "ctrl+alt+,",
        "mac": "ctrl+cmd+,",
        "when": "editorTextFocus && gtm:canPrev"
      },
      {
        "command": "gtm.current",
        "key": "ctrl+alt+/",
        "mac": "ctrl+cmd+/",
        "when": "editorTextFocus && gtm:enabled"
      },
      {
        "command": "gtm.next",
        "key": "ctrl+alt+.",
        "mac": "ctrl+cmd+.",
        "when": "editorTextFocus && gtm:canNext"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "package:vsix": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
